{
  "version": 1,
  "tier": 7,
  "taskId": "live-t7-project-finance-mgmt",
  "taskType": "software",
  "language": "py",
  "workspace": ".",
  "specRefs": [],
  "mvp": {
    "moduleDirs": [],
    "traceability": [
      {
        "id": "progress-calc",
        "dirs": [
          ".",
          "tests"
        ],
        "hint": "含 weight 加权进度计算（project_progress 或等价）",
        "pattern": {
          "source": "project_progress|weighted|weight",
          "flags": "i"
        }
      },
      {
        "id": "finance-match",
        "dirs": [
          ".",
          "tests"
        ],
        "hint": "含 match_records_to_budget / exec_rate（财务↔预算匹配）",
        "pattern": {
          "source": "match_records_to_budget|exec_rate",
          "flags": "i"
        }
      },
      {
        "id": "alerts",
        "dirs": [
          ".",
          "tests"
        ],
        "hint": "含 progress_alerts / budget_alerts（进度+预算预警）",
        "pattern": {
          "source": "progress_alerts|budget_alerts",
          "flags": "i"
        }
      },
      {
        "id": "monthly-report",
        "dirs": [
          ".",
          "tests"
        ],
        "hint": "含 monthly_report（月度报表聚合）",
        "pattern": {
          "source": "monthly_report",
          "flags": "i"
        }
      },
      {
        "id": "flask-stack",
        "dirs": [
          "."
        ],
        "hint": "app.py 含 Flask REST 路由",
        "pattern": {
          "source": "Flask|@app\\.(route|get|post|put|delete)",
          "flags": "i"
        }
      }
    ],
    "smoke": {
      "run": "command",
      "command": [
        "python",
        "app.py",
        "--smoke"
      ],
      "outputFile": "output/smoke_report.json",
      "jsonNotAllZero": true
    },
    "architectureScan": true,
    "requiredFiles": [
      "app.py",
      "models.py",
      "static/js/app.js",
      "templates/index.html",
      "requirements.txt",
      "config.yaml"
    ]
  },
  "codeact": {
    "maxSteps": 60,
    "timeoutMs": 2400000,
    "enableBrowser": false,
    "forbiddenPatterns": [
      "openctp",
      "np.random"
    ]
  },
  "llm": {
    "model": "${LLM_MODEL}",
    "baseUrl": "${LLM_BASE_URL}",
    "apiKeyEnv": "DEEPSEEK_API_KEY"
  }
}
